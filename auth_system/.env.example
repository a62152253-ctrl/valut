# Vaultly Environment Configuration
# Copy to .env and update with production values

# ═══ DATABASE ═══
DB_HOST=mysql
DB_USER=vaultly_user
DB_PASS=change_me_secure_password_12345
DB_NAME=vaultly_db
MYSQL_ROOT_PASSWORD=change_me_root_password_12345

# ═══ APPLICATION ═══
APP_ENV=production
APP_DEBUG=false
APP_URL=https://vaultly.example.com
LOG_LEVEL=warning

# ═══ SMTP EMAIL CONFIGURATION ═══
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
MAIL_FROM=noreply@vaultly.example.com
MAIL_FROM_NAME=Vaultly Vault
SMTP_ENABLED=true

# ═══ SECURITY ═══
SESSION_TIMEOUT=3600
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict
FORCE_HTTPS=true
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000

# ═══ RATE LIMITING ═══
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PASSWORD_RESET=5/900
RATE_LIMIT_LOGIN=10/900
RATE_LIMIT_REGISTER=5/3600

# ═══ VAULT SECURITY ═══
VAULT_LOCK_TIMEOUT=900
VAULT_MAX_ATTEMPTS=5
VAULT_ATTEMPT_LOCKOUT=300
ENCRYPTION_ALGORITHM=AES-256-GCM

# ═══ EMAIL VERIFICATION ═══
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_EXPIRY=86400

# ═══ 2FA / TOTP ═══
TOTP_ENABLED=true
TOTP_ISSUER=Vaultly

# ═══ WEBAUTHN / PASSKEYS ═══
WEBAUTHN_ENABLED=true
WEBAUTHN_RP_ID=vaultly.example.com
WEBAUTHN_ORIGIN=https://vaultly.example.com

# ═══ CAPTCHA (optional, for future use) ═══
CAPTCHA_ENABLED=false
CAPTCHA_SECRET=your_captcha_secret
CAPTCHA_SITE_KEY=your_captcha_site_key

# ═══ MONITORING & LOGGING ═══
MONITORING_ENABLED=true
LOG_TO_FILE=true
LOG_PATH=/var/log/vaultly
ERROR_REPORTING=E_ALL
DISPLAY_ERRORS=false

# ═══ PERFORMANCE ═══
CACHE_ENABLED=true
OPCACHE_ENABLED=true
OPCACHE_MEMORY=128

# ═══ BACKUP & RETENTION ═══
BACKUP_ENABLED=true
BACKUP_PATH=/backups
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION=true

# ═══ CORS (if using separate frontend) ═══
CORS_ENABLED=false
CORS_ORIGINS=https://example.com

# ═══ API VERSIONING ═══
API_VERSION=v1
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT=100/3600

# ═══ ALLOWED HOSTS ═══
ALLOWED_HOSTS=vaultly.example.com,www.vaultly.example.com,localhost,127.0.0.1

# ═══ DOCKER SECRETS (for Docker Swarm/Kubernetes) ═══
# When using Docker Secrets, set these to file paths:
# DB_PASS_FILE=/run/secrets/db_password
# SMTP_PASS_FILE=/run/secrets/smtp_password
