{
  "name": "vaultly/vaultly",
  "description": "Secure password manager and vault system",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "phpmailer/phpmailer": "^6.9",
    "paragonie/random_compat": "^9.99"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "classmap": [
      "includes/"
    ],
    "psr-4": {
      "Vaultly\\": "src/"
    }
  },
  "scripts": {
    "test": "phpunit tests/",
    "test-coverage": "phpunit --coverage-html coverage/ tests/",
    "lint": "php -l includes/*.php",
    "security-check": "composer audit"
  },
  "config": {
    "platform": {
      "php": "8.2"
    }
  }
}
